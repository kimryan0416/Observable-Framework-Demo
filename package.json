{
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "rimraf docs/.observablehq/cache",
    "build": "rimraf dist && observable build",
    "dev": "observable preview",
    "predeploy": "npm run build",
    "deploy_mac": "touch dist/.nojekyll && gh-pages -d dist -b gh-pages",
    "deploy_windows": "type nul > dist/.nojekyll && gh-pages -d dist -b gh-pages",
    "observable": "observable"
  },
  "dependencies": {
    "@observablehq/framework": "^1.13.3",
    "gh-pages": "^6.3.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}